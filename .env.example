# .env.example
# Copy this file to .env and customize.
# NEVER commit a real .env or any file containing live credentials.
# See AGENTS.md §3 (Security & Privacy) and PRD §9 (Technical Architecture).
#
# This project defaults to fully local/air-gapped operation.
# Cloud access (if any) requires explicit --cloud flag + consent + ledger.

# --- Local LLM (Ollama) ---
# Default host for local Ollama server.
OLLAMA_HOST=http://localhost:11434

# --- Air-gap / Egress kill switch ---
# Set to 1 to hard-block ALL off-machine calls (even with --cloud).
# Matches PRD §10 kill switch and AGENTS "SECOND_BRAIN_AIRGAP=1".
SECOND_BRAIN_AIRGAP=0

# --- Data / Notes root (optional override) ---
# Where your personal notes live. Used by ingest and retrieval.
# SECOND_BRAIN_DATA_DIR=~/notes

# --- Optional Cloud Provider Keys (PLACEHOLDERS ONLY) ---
# Use ONLY when you explicitly pass --cloud and accept the cost/egress.
# Rotate any real keys immediately if they ever appear here.
# OPENAI_API_KEY=sk-your-openai-key-here
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# --- LiteLLM / Model config (see config/models.yaml) ---
# LITELLM_CONFIG_PATH=config/models.yaml

# --- Development / Debug (optional) ---
# LOG_LEVEL=INFO
# SECOND_BRAIN_DEBUG=0

# Notes:
# - .env is gitignored.
# - Only .env.example (this file with placeholders) may be committed.
# - Aligns with frozen stack: local embeddings + Ollama by default.